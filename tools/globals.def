# Per-env mutable-state inventory (see docs/DESIGN.md §2).
#
# Every writable symbol in libnethack (tools/global_baseline.txt) either gets
# an entry here (migrated into struct nh_ctx) or a justified entry in
# tools/global_whitelist.txt. tools/gen_ctx.py generates the struct, accessor
# macros, and init code from this file; run it after every edit:
#
#   python3 tools/gen_ctx.py
#
# Format (pipe-separated, '#' comments, whitespace trimmed):
#
#   scope | heat | type | name | dims | init
#
#   scope: 'global' for true globals (accessor emitted into nh_ctx_gen.h,
#          visible everywhere), or the defining .c file's basename
#          (e.g. 'track.c') for file statics (accessor emitted into
#          include/nh_ctx_files/<file>.h, included only by that file).
#   heat:  'hot' (touched every step; packed first, prefetch-covered) or
#          'cold'. Classify from profiles, not intuition.
#   type:  C type as written in the original declaration.
#   dims:  array suffix, e.g. '[50]' or '[21][80]'; empty for scalars.
#          Must compile inside hack.h context — use literals for macros
#          that are private to the defining file.
#   init:  0 = zero-initialized (.bss/.common; calloc covers it).
#          1 = has a non-zero initializer (.data). The original definition
#          becomes 'const <type> nh_tmpl_<name><dims> = <original init>;'
#          at its original site, and nh_ctx_new() memcpys it in.
#
# Special forms:
#   type containing '{NAME}' is a full declarator with a placeholder
#   (function pointers etc.); dims must be empty.
#   Fields initialized with addresses of other ctx fields (e.g.
#   subrooms = &rooms[N]) use init=0 here plus an assignment in the
#   handwritten src/nh_ctx_fixup.c.
#
# ---------------------------------------------------------------------------
# track.c — hero movement ring (first migrated slice)
track.c | cold | int   | utcnt  |      | 0
track.c | cold | int   | utpnt  |      | 0
track.c | cold | coord | utrack | [50] | 0

# ---------------------------------------------------------------------------
# decl.c — the central globals file. Heat: step-hot scalars/pointers first;
# the big structs (u, level, youmonst, flags) are hot too but dominate their
# own cache lines regardless of placement.
